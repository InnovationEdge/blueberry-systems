{
  "rewrites": [
    { "source": "/software-development", "destination": "/software-development/index.html" },
    { "source": "/software-development/", "destination": "/software-development/index.html" },
    { "source": "/product-marketing", "destination": "/product-marketing/index.html" },
    { "source": "/product-marketing/", "destination": "/product-marketing/index.html" },
    { "source": "/product-design", "destination": "/product-design/index.html" },
    { "source": "/product-design/", "destination": "/product-design/index.html" },
    { "source": "/business-consulting", "destination": "/business-consulting/index.html" },
    { "source": "/business-consulting/", "destination": "/business-consulting/index.html" },

    { "source": "/ka/software-development", "destination": "/ka/software-development/index.html" },
    { "source": "/ka/software-development/", "destination": "/ka/software-development/index.html" },
    { "source": "/ka/product-marketing", "destination": "/ka/product-marketing/index.html" },
    { "source": "/ka/product-marketing/", "destination": "/ka/product-marketing/index.html" },
    { "source": "/ka/product-design", "destination": "/ka/product-design/index.html" },
    { "source": "/ka/product-design/", "destination": "/ka/product-design/index.html" },
    { "source": "/ka/business-consulting", "destination": "/ka/business-consulting/index.html" },
    { "source": "/ka/business-consulting/", "destination": "/ka/business-consulting/index.html" },

    { "source": "/ru/software-development", "destination": "/ru/software-development/index.html" },
    { "source": "/ru/software-development/", "destination": "/ru/software-development/index.html" },
    { "source": "/ru/product-marketing", "destination": "/ru/product-marketing/index.html" },
    { "source": "/ru/product-marketing/", "destination": "/ru/product-marketing/index.html" },
    { "source": "/ru/product-design", "destination": "/ru/product-design/index.html" },
    { "source": "/ru/product-design/", "destination": "/ru/product-design/index.html" },
    { "source": "/ru/business-consulting", "destination": "/ru/business-consulting/index.html" },
    { "source": "/ru/business-consulting/", "destination": "/ru/business-consulting/index.html" },

    { "source": "/((?!software-development|product-marketing|product-design|business-consulting|ka/|ru/|assets|team|.*\\.[a-z0-9]+).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:name(favicon|favicon-32|favicon-512|favicon-day|favicon-night|apple-touch-icon|og-image|logo-blue|logo-white|logo-brand-blue|logo-brand-white|logo-brand-full-blue|logo-brand-full-white|logo-mark-blue|logo-mark-white).:ext(svg|png|ico|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(robots.txt|humans.txt|sitemap.xml|site.webmanifest)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=3600" }
      ]
    },
    {
      "source": "/.well-known/security.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
